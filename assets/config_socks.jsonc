{
    // SOCKS代理服务器配置
    "proxy_port": 1080, // 代理服务器监听端口
    "max_connections": 3000, // 最大连接数量
    "timeout": 30, // 超时时间（秒）
    "bind_host": "0.0.0.0", // 绑定地址，0.0.0.0表示监听所有接口
    // IP白名单配置
    "enable_ip_whitelist": true,
    "ip_whitelist": [
        "127.0.0.1", // 本地开发
        "192.168.5.35", // 本地开发: MAC
        "172.16.192.151", // 9
        "172.16.194.149",  // 13
        "172.16.194.91",  // 13
        "172.16.194.254" // 13 
    ],
    // 域名白名单配置
    "enable_domain_whitelist": false,
    "domain_whitelist": [
    ]
}